# API Configuration
host=0.0.0.0
port=8000
debug=true
environment=development

# CORS Configuration
cors_origins=http://localhost:3000,http://localhost:5000

# Authentication
jwt_secret=your_super_secret_jwt_key_here_change_in_production_123456789
jwt_algorithm=HS256

# Database Configuration
mongodb_uri=mongodb://localhost:27017/medical_diagnosis

# AI Services Configuration
openai_api_key=your_openai_api_key_here
openai_model=gpt-3.5-turbo
openai_max_tokens=1000
openai_temperature=0.3

# Hugging Face Configuration
hf_model_name=dmis-lab/biobert-base-cased-v1.1
hf_cache_dir=./models/huggingface

# Vector Database Configuration
vector_db_path=./data/vector_db
embedding_dimension=768

# File Upload Configuration
max_file_size=10485760
allowed_file_types=image/jpeg,image/png,image/gif,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
upload_dir=./uploads

# OCR Configuration
tesseract_path=None

# Logging Configuration
log_level=INFO
log_file=./logs/ai_services.log
log_format=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Agent Configuration
agent_timeout=30
max_concurrent_agents=5

# Medical Knowledge Base
knowledge_base_path=./data/medical_knowledge
symptom_database_path=./data/symptoms.json
condition_database_path=./data/conditions.json

# Caching Configuration
cache_ttl=3600
redis_url=None

# Monitoring Configuration
enable_metrics=true
metrics_port=8001
